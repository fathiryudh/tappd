PORT=8000
# Preferred: set DB_* vars and let the app build DATABASE_URL for PostgreSQL.
# DATABASE_URL overrides everything if you set it explicitly.
DB_HOST=aws-1-ap-southeast-1.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.[project-ref]
DB_PASSWORD=
DB_SCHEMA=public
DB_USE_LIBPQ_COMPAT=true
DB_SSLMODE=require
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@[host]:5432/postgres?schema=public&uselibpqcompat=true&sslmode=require
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
CLIENT_ORIGIN=http://localhost:5173
NODE_ENV=development
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
DIGEST_EMAIL=
WEBHOOK_BASE_URL=
BOT_ADMIN_EMAIL=admin@example.com
