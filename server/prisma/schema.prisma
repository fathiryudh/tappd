generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  passwordHash       String
  refreshToken       String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  scopeDivisionId    String?
  scopeBranchId      String?
  digestEmails       String[]            @default([])
  notificationEvents NotificationEvent[]
  officers           Officer[]
  Task               Task[]
  Branch             Branch?             @relation(fields: [scopeBranchId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  Division           Division?           @relation(fields: [scopeDivisionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Division {
  id       String    @id @default(cuid())
  name     String    @unique
  officers Officer[]
  User     User[]
}

model Branch {
  id       String    @id @default(cuid())
  name     String    @unique
  officers Officer[]
  User     User[]
}

model Officer {
  id                 String              @id @default(cuid())
  telegramId         String?             @unique
  telegramName       String?
  name               String?
  rank               String?
  adminId            String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  phoneNumber        String              @unique
  role               String              @default("OFFICER")
  divisionId         String?
  branchId           String?
  availability       Availability[]
  notificationEvents NotificationEvent[]
  admin              User?               @relation(fields: [adminId], references: [id])
  branch             Branch?             @relation(fields: [branchId], references: [id])
  division           Division?           @relation(fields: [divisionId], references: [id])

  @@index([adminId])
  @@index([divisionId])
}

model Availability {
  id         String             @id @default(cuid())
  officerId  String
  date       DateTime
  status     AvailabilityStatus
  reason     String?
  rawMessage String
  notes      String?
  createdAt  DateTime           @default(now())
  splitDay   Boolean            @default(false)
  officer    Officer            @relation(fields: [officerId], references: [id], onDelete: Cascade)

  @@unique([officerId, date])
  @@index([officerId])
  @@index([date])
}

model NotificationEvent {
  id        String    @id @default(cuid())
  adminId   String
  officerId String
  title     String
  message   String
  eventDate DateTime
  readAt    DateTime?
  createdAt DateTime  @default(now())
  admin     User      @relation(fields: [adminId], references: [id], onDelete: Cascade)
  officer   Officer   @relation(fields: [officerId], references: [id], onDelete: Cascade)

  @@index([adminId, createdAt])
  @@index([adminId, readAt])
  @@index([officerId])
}

model Task {
  id          String       @id
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  tag         String?
  position    Int          @default(0)
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime
  userId      String
  User        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
}

enum AvailabilityStatus {
  IN
  OUT
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  YAPPD
}
